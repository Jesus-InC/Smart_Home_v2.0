[Unit]
Description=SmartHome Decision central de vision
After=network-online.target mosquitto.service
Wants=network-online.target

[Service]
Type=simple
User=jibarra777
WorkingDirectory=/home/jibarra777/Smart_Home_v2/codigos/Maestro_Raspberry/Decision_Vision
ExecStart=/home/jibarra777/Smart_Home_v2/.SH2/bin/python decision_garaje.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
